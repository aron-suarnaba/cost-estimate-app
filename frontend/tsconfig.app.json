{
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.dotts/tsconfig.app.tsbuildinfo",
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode configuration rules */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting / Safety rules checking */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,

    /* 🟢 ADD PATH ALIAS MAPPING HERE (No baseUrl needed) */
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src", "src/custom.d.ts"]
}